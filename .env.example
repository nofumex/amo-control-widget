# Runtime profile: local, development, test, staging, production.
APP_ENV=development
INTEGRATION_MODE=private
PUBLIC_BASE_URL=http://localhost:8000

# Development-only auth. Must be false in production.
ALLOW_DEV_AUTH=true
WIDGET_DEV_TENANT_ID=1

# amoCRM/Kommo OAuth integration settings.
AMO_CLIENT_ID=replace-with-client-id
AMO_CLIENT_SECRET=replace-with-client-secret
AMO_REDIRECT_URI=http://localhost:8000/api/oauth/callback

# Persistence and worker dependencies.
DATABASE_URL=postgresql+asyncpg://amo:amo@postgres:5432/amo_control
REDIS_URL=redis://redis:6379/0

# Secrets. Use strong random values in staging/production.
FERNET_KEY=
APP_SECRET_KEY=change-me-dev-secret
WIDGET_SIGNING_SECRET=change-me-widget-signing-secret
WEBHOOK_SHARED_SECRET=change-me-webhook-secret
INTERNAL_ADMIN_TOKEN=change-me-admin-token

# CORS: comma-separated explicit dev origins. amoCRM/Kommo production origins are regex-allowed by the app.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# Operational controls.
LOG_LEVEL=INFO
AMO_RPS_LIMIT=6
WIDGET_SIGNATURE_TTL_SECONDS=300
WEBHOOK_SIGNATURE_TTL_SECONDS=300
MAX_WEBHOOK_PAYLOAD_BYTES=256000
REPORT_SNAPSHOT_RETENTION_DAYS=180
WEBHOOK_INBOX_RETENTION_DAYS=30
DELIVERY_LOG_RETENTION_DAYS=180
